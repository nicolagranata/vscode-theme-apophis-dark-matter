    "tokenColors": [
        {
            "name": "Comment text",
            "scope": "comment",
            "settings": {
                "fontStyle": "italic",
                "foreground": "#8baed4dd"
            }
        },
        {
            "name": "Comment punctuation",
            "scope": "punctuation.definition.comment, punctuation.whitespace.comment",
            "settings": {
                "fontStyle": "italic",
                "foreground": "#6c7d8fdd"
            }
        },
        {
            "name": "String",
            "scope": "string, string.unquoted",
            "settings": {
                "foreground": "#9cac8add"
            }
        },
        {
            "name": "Heredoc",
            "scope": "string.unquoted.heredoc",
            "settings": {
                "foreground": "#e7f8e7dd"
            }
        },
        {
            "name": "phpdoc",
            "scope": "keyword.other.phpdoc, storage.type.class.jsdoc, comment.block.documentantion.ts",
            "settings": {
                "foreground": "#e2d518dd",
                "fontStyle": "italic"
            }
        },
        {
            "name": "embedded ruby in string delimiters",
